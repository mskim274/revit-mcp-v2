<Window x:Class="RevitMCP.Plugin.UI.UpdateNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Revit MCP — 업데이트 알림"
        Width="460"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        WindowStyle="SingleBorderWindow"
        Background="#1E1E1E"
        Foreground="White"
        FontFamily="Segoe UI"
        FontSize="13">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Margin" Value="4,0"/>
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4A4A4A"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#5B8EFB"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#6E9EFC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header: new version available -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Ellipse Width="10" Height="10" Fill="#4ADE80" VerticalAlignment="Center"/>
            <TextBlock Text="새 버전이 출시되었습니다"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="10,0,0,0"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Version comparison panel -->
        <Border Grid.Row="1"
                Background="#2A2A2A"
                CornerRadius="6"
                Padding="16"
                Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock Text="현재 버전"
                               Foreground="#888"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="CurrentVersionText"
                               Text="v0.0.0"
                               FontSize="20"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="→"
                           FontSize="22"
                           VerticalAlignment="Center"
                           Margin="16,0"
                           Foreground="#5B8EFB"/>

                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock Text="최신 버전"
                               Foreground="#888"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="LatestVersionText"
                               Text="v0.0.0"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="#4ADE80"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Release notes preview -->
        <Border Grid.Row="2"
                Background="#2A2A2A"
                CornerRadius="6"
                Padding="14,10"
                Margin="0,0,0,16">
            <StackPanel>
                <TextBlock Text="업데이트 내용"
                           Foreground="#888"
                           FontSize="12"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="ReleaseNotesText"
                           Text="Github Release Note 참조"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Snooze checkbox -->
        <CheckBox Grid.Row="3"
                  x:Name="SnoozeCheckBox"
                  Content="하루 동안 알리지 않음"
                  Foreground="White"
                  Margin="0,0,0,12"/>

        <!-- Status text (progress during download, message on completion/error) -->
        <TextBlock Grid.Row="4"
                   x:Name="StatusText"
                   Text=""
                   Foreground="#888"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"/>

        <!-- Action buttons -->
        <StackPanel Grid.Row="5"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="CloseButton"
                    Content="닫기"
                    Click="OnCloseClick"/>
            <Button x:Name="DownloadButton"
                    Content="⬇  다운로드 및 설치"
                    Style="{StaticResource PrimaryButton}"
                    Click="OnDownloadClick"/>
        </StackPanel>
    </Grid>
</Window>
