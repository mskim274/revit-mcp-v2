{
  "name": "@kimminsub/revit-mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server for Autodesk Revit — 20 tools for read / query / create / modify / view operations, driven by Claude and other MCP clients.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "revit-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "revit",
    "autodesk",
    "bim",
    "claude",
    "anthropic",
    "ai",
    "llm"
  ],
  "author": "mskim274",
  "license": "MIT",
  "homepage": "https://github.com/mskim274/revit-mcp-v2#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mskim274/revit-mcp-v2.git",
    "directory": "server"
  },
  "bugs": {
    "url": "https://github.com/mskim274/revit-mcp-v2/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@kimminsub/mcp-cad-core": "*",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
